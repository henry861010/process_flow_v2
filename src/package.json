{
  "name": "process-flow-geometry-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JavaScript geometry kernel and OpenCascade.js CAD exporter for process-flow geometry documents.",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./data": "./data/index.js",
    "./exporters/cad": "./exporters/cad.js",
    "./kernel": "./kernel/index.js",
    "./process": "./process/index.js",
    "./process/process-bgaBump": "./process/process-bgaBump.js",
    "./process/process-c4Bump": "./process/process-c4Bump.js",
    "./process/process-molding": "./process/process-molding.js",
    "./process/process-panel": "./process/process-panel.js",
    "./process/process-pnp": "./process/process-pnp.js",
    "./process/process-rdl": "./process/process-rdl.js",
    "./process/process-wafer": "./process/process-wafer.js",
    "./process/rdl-layer-thickness": "./process/rdl-layer-thickness.js",
    "./process/status": "./process/status.js",
    "./utils/math": "./utils/math.js",
    "./utils/polygon": "./utils/polygon.js"
  },
  "scripts": {
    "example": "node ./examples/generate-json.js",
    "test": "node --test",
    "example:json": "node ./examples/generate-json.js --format json",
    "example:cad": "node ./examples/generate-json.js --format all --output /tmp/process-flow-example"
  },
  "dependencies": {
    "opencascade.js": "beta"
  },
  "engines": {
    "node": ">=20"
  }
}
